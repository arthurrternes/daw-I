
<%- include('../cabecalho.ejs')%>

    <main class="container">
        <div class="page-header">
            <h2>Lista de Albuns</h2>
            <a href="/album/add" class="btn btn-success">+ Novo Album</a>
        </div>
            <form method="post">
 <input type="text" name="pesquisar" placeholder="Autista">
 <input type="submit" value="Buscar">
</form>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome do album</th>
                        <th>artista</th>
                        <th>Ano de lançamento</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <%albums.forEach(album => {%>
                    <tr>
                        <td><%=album.nome%></td>
                        <td><%=album.artista%></td>
                        <td><%=album.ano%></td>
                        <td><a href="/album/del/<%=album.id%>" class="link">Excluir</a>
                         <a href="/album/edit/<%=album.id%>" class="link">Editar</a></td>
                    </tr>
                    <%})%>
                    
                </tbody>
            </table>
        </div>
    </main>

<%- include('../rodape.ejs')%>
