
<%- include('../cabecalho.ejs')%>

    <main class="container">
        <div class="page-header">
            <h2>Lista de Músicas</h2>
            <a href="/musica/add" class="btn btn-success">+ Nova Música</a>
        </div>

        <div class="table-container">
            <form method="post">
 <input type="text" name="pesquisar" placeholder="artista da Música">
 <input type="submit" value="Buscar">
</form>
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Artista</th>
                        <th>Gênero</th>
                        <th>Ano Lançamento</th>
                        <th>Duração</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <%musicas.forEach(musica => {%>
                    <tr>
                        <td><%=musica.nome%></td>
                         <td><%=musica.artista%></td>
                        <td><%=musica.genero%></td>
                        <td><%=musica.anoLancamento%></td>
                        <td><%=musica.duracao%></td>
                        <td><a href="/musica/del/<%=musica.id%>">Excluir</a>
                            <a href="/musica/edit/<%=musica.id%>" class="link">Editar</a></td></td>
                    </tr>
                    <%})%>
                    
                </tbody>
            </table>
        </div>
    </main>

<%- include('../rodape.ejs')%>
